# Local development defaults to SQLite at data/inflowee.sqlite.
# Set DATABASE_URL only when you explicitly want to use Postgres.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/inflowee"
INNGEST_EVENT_KEY="evt_test_local"
INNGEST_SIGNING_KEY="sign_test_local"
# Optional local override for inngest dev server routing.
INNGEST_BASE_URL="http://127.0.0.1:8288"
CRON_SECRET="replace-with-a-cron-secret"
INFLOWEE_SESSION_SECRET="replace-with-a-random-secret"
INFLOWEE_OPERATOR_EMAIL="owner@example.com"
INFLOWEE_OPERATOR_LOGIN_CODE="replace-with-a-strong-login-code"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OpenAI-compatible AI provider.
# You can use OPENAI_* or the generic AI_* aliases.
# OpenAI:
# OPENAI_PROVIDER_NAME="OpenAI"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_API_KEY=""
#
# DeepSeek:
# OPENAI_PROVIDER_NAME="DeepSeek"
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
# OPENAI_MODEL="deepseek-chat"
# OPENAI_API_KEY=""
#
# SiliconFlow:
# OPENAI_PROVIDER_NAME="SiliconFlow"
# OPENAI_BASE_URL="https://api.siliconflow.cn/v1"
# OPENAI_MODEL="deepseek-ai/DeepSeek-V3"
# OPENAI_API_KEY=""
#
# DashScope OpenAI-compatible mode:
# OPENAI_PROVIDER_NAME="DashScope"
# OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# OPENAI_MODEL="qwen-plus"
# OPENAI_API_KEY=""
OPENAI_PROVIDER_NAME="OpenAI"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
