# Local development defaults to SQLite at data/inflowee.sqlite.
# Set DATABASE_URL only when you explicitly want to use Postgres.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/inflowee"
INNGEST_EVENT_KEY="evt_test_local"
INNGEST_SIGNING_KEY="sign_test_local"
# Optional local override for inngest dev server routing.
INNGEST_BASE_URL="http://127.0.0.1:8288"
CRON_SECRET="replace-with-a-cron-secret"
INFLOWEE_SESSION_SECRET="replace-with-a-random-secret"
INFLOWEE_OPERATOR_EMAIL="owner@example.com"
INFLOWEE_OPERATOR_LOGIN_CODE="replace-with-a-strong-login-code"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
