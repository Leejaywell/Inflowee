{
  "name": "inflowee",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "node --experimental-strip-types scripts/run-with-dev-env.ts dev",
    "prebuild": "node --experimental-strip-types scripts/prisma-prebuild.ts",
    "build": "next build",
    "start": "node --experimental-strip-types scripts/run-with-dev-env.ts start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "node --experimental-strip-types scripts/reset-dev.ts",
    "db:seed": "node --experimental-strip-types scripts/seed-dev.ts",
    "inngest:dev": "inngest-cli dev -u http://localhost:3000/api/inngest",
    "mcp": "tsx scripts/inflowee-mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.3.0",
    "inngest": "^3.31.1",
    "next": "16.2.6",
    "nodemailer": "^8.0.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^26.1.0",
    "prisma": "^6.9.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
